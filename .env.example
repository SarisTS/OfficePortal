# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Never commit real secrets.

# ---------- App ----------
APP_NAME=OfficePortal
APP_ENVIRONMENT=development          # development | staging | production
DEBUG=True                           # set to False outside dev

# ---------- Auth / JWT ----------
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# Rotate this whenever it leaks. Any rotation invalidates every issued token.
SECRET_KEY=replace-me-with-a-strong-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------- Database ----------
DATABASE_URL=postgresql+psycopg2://postgres:CHANGE_ME@localhost:5432/office_portal

# ---------- Google OAuth ----------
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---------- Email (Gmail SMTP) ----------
# EMAIL_HOST_PASSWORD must be a Gmail App Password (16 chars, no spaces in
# storage). See https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# ---------- CORS (optional) ----------
# Comma-separated allowlist. Defaults to localhost dev origins when unset
# (see app/core/config.py). MUST be an explicit list in staging/prod.
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# ---------- Logging (optional) ----------
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR  (default INFO)
# LOG_FORMAT: text | json                    (default text)
# Set LOG_FORMAT=json in any environment with a log aggregator
# (Datadog/CloudWatch/Loki) — one structured JSON record per line.
# LOG_LEVEL=INFO
# LOG_FORMAT=text
