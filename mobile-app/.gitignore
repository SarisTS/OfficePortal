# Flutter / Dart ignores.
# Cross-cutting ignores (.env, .DS_Store, .vscode, *.log) live at the
# monorepo root.

# Dart tooling
.dart_tool/
.packages
.pub-cache/
.pub/
.flutter-plugins
.flutter-plugins-dependencies

# Lockfile — deliberately gitignored while the project is in scaffold
# stage. The Flutter SDK in CI may resolve transitive deps differently
# than a contributor's local version, and a committed lockfile would
# cause noisy diffs on every fresh `flutter pub get`. Revisit when the
# dep set stabilises and the team standardises on a Flutter version.
pubspec.lock

# Flutter / Dart build output
build/

# Per-IDE Flutter metadata
*.iml
*.ipr
*.iws

# iOS build artefacts (generated by `flutter create`/`flutter build ios`)
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/flutter_export_environment.sh
ios/Flutter/Generated.xcconfig

# Android build artefacts
android/.gradle/
android/local.properties
android/app/release/

# Symbolicate / obfuscation artefacts
app.*.symbols
app.*.map.json
