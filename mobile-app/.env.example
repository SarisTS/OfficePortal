# Compile-time env. Pass with:
#   flutter run --dart-define-from-file=.env
# .env (no suffix) is gitignored; copy this file to .env to set values
# locally. Values bake into the build at compile time — there's no
# runtime .env file shipped in the bundle.

API_URL=http://10.0.2.2:8000
# Notes:
#   - Android emulator uses 10.0.2.2 to reach the host's localhost.
#   - iOS simulator can use 127.0.0.1 / localhost directly.
#   - Physical device on the same Wi-Fi: use the host's LAN IP.
