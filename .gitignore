# Monorepo-level .gitignore. Cross-cutting entries ONLY.
#
# Per-workspace ignores live in:
#   backend/.gitignore        Python/Alembic/pytest
#   admin-panel/.gitignore    Node/Vite/TypeScript
#   mobile-app/.gitignore     Flutter/Dart, iOS/Android build artefacts
#
# Add a rule here only if it applies to MORE THAN ONE workspace, or to
# the repo root itself.

# OS noise
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# Claude Code session files — local-only, never tracked.
# CLAUDE.md (uppercase) IS tracked: it carries monorepo-wide rules.
.claude/

# Environment overlays anywhere in the tree
.env
.env.local
.env.*.local

# Logs anywhere
*.log
logs/

# Coverage reports anywhere
coverage/
.nyc_output/
