# Monorepo-level gitignore. Each workspace (backend/, admin-panel/,
# mobile-app/) also has its own .gitignore for language-specific noise.
# Keep entries here cross-cutting only.

# OS noise
.DS_Store
Thumbs.db

# Editor + IDE
.vscode/
.idea/
*.swp
*~

# Harness files written by the local dev assistant — never tracked.
.claude/
claude.md

# JavaScript / TypeScript (admin-panel)
node_modules/
dist/
build/
.parcel-cache/
.vite/
*.tsbuildinfo
.npm/
.yarn/

# Environment overlays anywhere in the tree
.env
.env.local
.env.*.local

# Flutter / Dart (mobile-app)
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
ios/Pods/
ios/.symlinks/
android/.gradle/
android/app/release/
*.iml

# Logs
*.log
logs/

# Coverage reports
coverage/
.nyc_output/
