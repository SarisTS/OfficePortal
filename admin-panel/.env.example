# Copy to `.env.local` for your local dev. `.env.local` is gitignored.
# Only variables prefixed with VITE_ are exposed to the client bundle.

# Base URL of the FastAPI backend. No trailing slash.
# Local dev:  http://localhost:8000
# Staging:    https://staging-api.officeportal.example.com
# Production: https://api.officeportal.example.com
VITE_API_URL=http://localhost:8000
